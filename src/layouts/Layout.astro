  {
    title: 'Vektorer & Geometri (3D)',
    slug: 'vektorer-og-analytisk-geometri',
    level: 'A',
    icon: 'M14 10l-2 1m-8.284-.284A2 2 0 112 8.716l2.186 2.186M10 20v-6m0 0l-2-2m2 2l2-2m-2-2H4a2 2 0 00-2 2v6a2 2 0 002 2h6a2 2 0 002-2v-6z',
    items: [
      { slug: 'matematik-a/vektorer-og-analytisk-geometri/parameterfremstilling-plan-og-rum', title: 'Parameterfremstilling' },
      { slug: 'matematik-a/vektorer-og-analytisk-geometri/skalar-og-krydsprodukt', title: 'Skalar- & Krydsprodukt' },
      { slug: 'matematik-a/vektorer-og-analytisk-geometri/kuglens-ligning', title: 'Kuglens Ligning' },
      { slug: 'matematik-a/vektorer-og-analytisk-geometri/afstande', title: 'Afstande i Rummet' },
    ]
  },
  {
    title: 'Infinitesimalregning (Avanc.)',
    slug: 'avanceret-infinitesimalregning',
    level: 'A',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
    items: [
      { slug: 'matematik-a/avanceret-infinitesimalregning/graensevaerdier-og-kontinuitet', title: 'Grænseværdier' },
      { slug: 'matematik-a/avanceret-infinitesimalregning/integrationsregneregler', title: 'Integrationsregler' },
