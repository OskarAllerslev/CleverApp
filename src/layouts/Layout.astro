          'ugrupperet-hyppighed-1',
          'ugrupperet-median-1',
          'ugrupperet-boksplot-1'
        ],
        'tal-og-algebra/broeker': [
          'broeker-q1',
          'broeker-q2',
          'broeker-q3'
        ],
        'tal-og-algebra/ligninger': [
          'ligninger-q1',
          'ligninger-q2',
          'ligninger-q3'
        ],
        'tal-og-algebra/potens-og-rod': [
          'potens-q1',
          'potens-q2',
          'potens-q3'
        ],
        'tal-og-algebra/procent-og-rente': [
          'procent-quiz-1',
          'procent-quiz-2',
          'procent-quiz-3'
        ],
        'tal-og-algebra/regningsarter': [
          'regningsarter-quiz-1',
          'regningsarter-quiz-2',
          'regningsarter-quiz-3'
        ]
      };

      function updateXPBadges() {
        const badges = document.querySelectorAll('.xp-badge');
        badges.forEach((badge) => {
          const slug = badge.getAttribute('data-slug');
          if (!slug) return;
          
          const quizzes = quizzesBySlug[slug] || [];
          const totalXP = quizzes.length > 0 ? quizzes.length * 50 : 150;
          
          let earnedXP = 0;
          let allSolved = quizzes.length > 0;
          
          if (quizzes.length > 0) {
            quizzes.forEach(quizId => {
              const isSolved = localStorage.getItem(`clevermat-quiz-${quizId}`) === 'correct';
              if (isSolved) {
                const attempts = parseInt(localStorage.getItem(`clevermat-quiz-attempts-${quizId}`) || '0', 10);
                const points = Math.max(10, 50 - attempts * 15);
                earnedXP += points;
              } else {
                allSolved = false;
              }
            });
          } else {
            earnedXP = parseInt(localStorage.getItem(`clevermat-mock-xp-${slug}`) || '0', 10);
            allSolved = earnedXP >= totalXP;
          }
          
          // Check if parent link is active to adjust contrast accordingly
          const link = badge.closest('a');
          const isLinkActive = link && (
            link.getAttribute('href').replace(/\/$/, '') === window.location.pathname.replace(/\/$/, '') ||
            window.location.pathname.replace(/\/$/, '').endsWith(link.getAttribute('href').replace(/\/$/, ''))
          );
          
          // Generate SVG Icon based on completion status
          let iconSvg = '';
          if (allSolved) {
            // Trophy icon SVG
            iconSvg = `<svg class="inline-block w-2.5 h-2.5 mr-0.5 align-middle shrink-0" fill="currentColor" viewBox="0 0 20 20" style="margin-top: -1px;"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>`;
          } else if (earnedXP > 0) {
            // Bolt icon SVG
            iconSvg = `<svg class="inline-block w-2.5 h-2.5 mr-0.5 align-middle shrink-0" fill="currentColor" viewBox="0 0 20 20" style="margin-top: -1px;"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>`;
          } else {
            // Sparkles SVG
            iconSvg = `<svg class="inline-block w-2.5 h-2.5 mr-0.5 align-middle shrink-0" fill="currentColor" viewBox="0 0 20 20" style="margin-top: -1px;"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
          }

          badge.innerHTML = `<span class="inline-flex items-center justify-center gap-0.5">${iconSvg}<span>${earnedXP} / ${totalXP} XP</span></span>`;
          
          if (isLinkActive) {
            // High-contrast colors when selected (dark text on light bg, neon/bright text on dark bg)
            if (allSolved) {
              badge.className = "xp-badge text-[9px] font-outfit font-extrabold px-1.5 py-0.5 rounded-full bg-emerald-200 text-emerald-950 border border-emerald-300 dark:bg-emerald-500/20 dark:text-emerald-400 dark:border-emerald-500/30 transition-all";
            } else if (earnedXP > 0) {
              badge.className = "xp-badge text-[9px] font-outfit font-extrabold px-1.5 py-0.5 rounded-full bg-brand-200 text-brand-950 border border-brand-300 dark:bg-purple-500/20 dark:text-purple-300 dark:border-purple-500/30 transition-all";
            } else {
              badge.className = "xp-badge text-[9px] font-outfit font-extrabold px-1.5 py-0.5 rounded-full bg-slate-200 text-slate-900 border border-slate-300 dark:bg-purple-950/40 dark:text-purple-300 dark:border-purple-900/30 transition-all";
            }
          } else {
            // Normal (non-active) badge colors
            if (allSolved) {
              badge.className = "xp-badge text-[9px] font-outfit font-bold px-1.5 py-0.5 rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300 border border-emerald-250/20 dark:border-emerald-800/20 transition-all";
            } else if (earnedXP > 0) {
              badge.className = "xp-badge text-[9px] font-outfit font-bold px-1.5 py-0.5 rounded-full bg-brand-50 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300 border border-brand-200/30 dark:border-brand-800/30 transition-all";
            } else {
              badge.className = "xp-badge text-[9px] font-outfit font-bold px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-500 dark:bg-slate-900/60 dark:text-slate-500 border border-slate-200/20 dark:border-slate-800/20 transition-all";
            }
          }
        });
      }

      // Initial update
      updateXPBadges();

      // Listen for correct quiz completions to update XP dynamically
      window.addEventListener('clevermat-xp-earned', () => {
        // Note: Actual XP storage updates (session or guest) are now handled directly
        // by the ExerciseHub component using xpService.addXP(points).
        updateXPBadges();
      });

      // Run KaTeX immediately
      applyKatex();
      // Run it on window load to ensure elements are settled
      window.addEventListener('load', applyKatex);

      // Term Tooltips repositioning logic to prevent off-screen overflow
      function setupTermTooltips() {
        const termContainers = document.querySelectorAll('.term-container');
        
        termContainers.forEach(container => {
          const tooltip = container.querySelector('.term-tooltip') as HTMLElement | null;
          const arrow = container.querySelector('.term-arrow') as HTMLElement | null;
          if (!tooltip || !arrow) return;

          function positionTooltip() {
            if (!container || !tooltip || !arrow) return;
            const rect = container.getBoundingClientRect();
            const tooltipWidth = 256; // w-64 is 256px
            const halfWidth = tooltipWidth / 2;
            const termCenter = rect.left + rect.width / 2;
            
            let minLeft = 16;
            const sidebar = document.getElementById('desktop-sidebar');
            if (sidebar && window.innerWidth >= 768) {
              const sidebarRect = sidebar.getBoundingClientRect();
              if (sidebarRect.width > 0) {
                minLeft = sidebarRect.right + 16;
              }
            }
            
            const maxRight = window.innerWidth - 16;
            let offset = 0;
            
            if (termCenter - halfWidth < minLeft) {
              offset = minLeft - (termCenter - halfWidth);
            } else if (termCenter + halfWidth > maxRight) {
              offset = maxRight - (termCenter + halfWidth);
            }
            
            if (offset === 0) {
              tooltip.style.transform = '';
              arrow.style.left = '';
            } else {
              // Apply offset to tooltip translation
              tooltip.style.transform = `translateX(calc(-50% + ${offset}px))`;
              
              // Clamp and apply offset to arrow translation (opposite direction)
              const maxArrowOffset = halfWidth - 20;
              const clampedOffset = Math.max(-maxArrowOffset, Math.min(maxArrowOffset, offset));
              arrow.style.left = `calc(50% - ${clampedOffset}px)`;
            }
          }

          container.addEventListener('mouseenter', positionTooltip);
          container.addEventListener('focus', positionTooltip);
          container.addEventListener('touchstart', positionTooltip, { passive: true });
        });
      }

      // details dropdown collapse helper
      function setupDetailsCollapseButtons() {
        const detailsElements = document.querySelectorAll('details');
        
        detailsElements.forEach(details => {
          if (details.querySelector('.details-collapse-btn')) return;

          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'details-collapse-btn w-full mt-6 py-2.5 px-4 text-xs font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 bg-slate-100 hover:bg-slate-200/80 dark:bg-slate-900/60 dark:hover:bg-slate-800/80 border border-slate-200 dark:border-slate-800 rounded-lg transition-all duration-150 flex items-center justify-center gap-1.5 cursor-pointer';
          btn.innerHTML = `
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
            </svg>
            Luk og fold eksempel sammen
          `;

          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            details.scrollIntoView({ behavior: 'smooth', block: 'center' });
            details.open = false;
          });

          details.appendChild(btn);
        });
      }

      // Initialize tooltips and collapse buttons immediately and on load
      setupTermTooltips();
      setupDetailsCollapseButtons();
      window.addEventListener('load', () => {
        setupTermTooltips();
        setupDetailsCollapseButtons();
      });
    </script>
  </body>
</html>
