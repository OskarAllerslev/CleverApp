---
import '../styles/global.css';
import { LevelProgressBar } from '../components/LevelProgressBar.tsx';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description = "Visual, interaktiv læring af Matematik C, B og A på gymnasialt niveau.", currentSlug } = Astro.props;

// Curriculum navigation structure
const modules = [
  {
    title: 'Tal og Algebra',
    slug: 'tal-og-algebra',
    level: 'C',
    icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4',
    items: [
      { slug: 'tal-og-algebra/regningsarter', title: 'Regningsarter' },
      { slug: 'tal-og-algebra/broeker', title: 'Brøker' },
      { slug: 'tal-og-algebra/ligninger', title: 'Ligninger og Formler' },
      { slug: 'tal-og-algebra/potens-og-rod', title: 'Potenser og Rødder' },
      { slug: 'tal-og-algebra/procent-og-rente', title: 'Procent og Rente' },
