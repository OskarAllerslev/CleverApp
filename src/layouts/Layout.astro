                          <span class="xp-badge text-[9px] font-outfit font-bold px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-500 dark:bg-slate-900 dark:text-slate-500 border border-slate-200/20 dark:border-slate-800/20 transition-all" data-slug={item.slug}>
                            0 XP
                          </span>
                          {isActive(item.slug) && (
                            <span class="h-1.5 w-1.5 rounded-full bg-brand-500 dark:bg-purple-400 animate-pulse" />
                          )}
