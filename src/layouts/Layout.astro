          )}
        )}

        <!-- Mobile User Profile Footer Section -->
        <div id="mobile-sidebar-user-footer" class="border-t border-slate-200 dark:border-slate-800/80 pt-4 mt-auto shrink-0"></div>
      </aside>

      <!-- Main Content Area -->
      <main class="flex flex-1 flex-col py-8 px-4 md:px-8 min-w-0">
        <div class="w-full max-w-4xl mx-auto flex flex-col flex-1">
          <slot />

        <!-- Next / Prev Navigation inside Docs -->
        {currentSlug && (prevItem || nextItem) && (
          <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800/80 flex flex-col sm:flex-row gap-4 justify-between">
            {prevItem ? (
              <a href={`/docs/${prevItem.slug}`} class="flex flex-1 flex-col items-start rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:bg-slate-50 dark:hover:bg-slate-900/40 hover:border-brand-500 dark:hover:border-brand-400 transition-all duration-200 group">
                <span class="text-xs text-slate-400 dark:text-slate-500 mb-1">Forrige emne</span>
                <span class="flex items-center gap-1 font-semibold text-slate-800 dark:text-slate-200 group-hover:text-brand-600 dark:group-hover:text-brand-400 font-outfit">
                  <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                  {prevItem.title}
                </span>
              </a>
            ) : (
              <div class="flex-1 hidden sm:block" />
            )}

            {nextItem ? (
              <a href={`/docs/${nextItem.slug}`} class="flex flex-1 flex-col items-end rounded-xl border border-slate-200 dark:border-slate-800 p-4 hover:bg-slate-50 dark:hover:bg-slate-900/40 hover:border-brand-500 dark:hover:border-brand-400 transition-all duration-200 group">
                <span class="text-xs text-slate-400 dark:text-slate-500 mb-1">Næste emne</span>
                <span class="flex items-center gap-1 font-semibold text-slate-800 dark:text-slate-200 group-hover:text-brand-600 dark:group-hover:text-brand-400 font-outfit">
                  {nextItem.title}
                  <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            ) : (
              <div class="flex-1 hidden sm:block" />
            )}
          </div>
        )}
        </div>
      </main>
    </div>

    <!-- Footer -->
    <footer class="mt-auto border-t border-slate-200 dark:border-slate-800/80 bg-white dark:bg-slate-950 transition-colors duration-200">
      <div class="mx-auto px-4 py-8 sm:px-6 lg:px-8 text-center text-slate-500 dark:text-slate-400">
        <p class="font-outfit font-medium">&copy; {new Date().getFullYear()} CleverMat. Udviklet til Matematik C-, B- og A-niveau efter de officielle læreplaner.</p>
        <p class="text-xs mt-2 italic text-slate-400 dark:text-slate-500">"Matematik handler ikke om tal, ligninger eller algoritmer: det handler om forståelse." — William Paul Thurston</p>
      </div>
    </footer>

    <!-- Script for level toggle, dark mode, mobile menu, folding, and KaTeX auto-render -->
    <script>
      import renderMathInElement from 'katex/dist/contrib/auto-render.mjs';

      // KaTeX Auto-Render function
      function applyKatex() {
        renderMathInElement(document.body, {
          delimiters: [
            { left: '$$', right: '$$', display: true },
            { left: '$', right: '$', display: false }
          ],
          throwOnError: false
        });
      }

      // Dark Mode Logic
      const themeToggleBtn = document.getElementById('theme-toggle');

      themeToggleBtn?.addEventListener('click', () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      });

      // Level Toggle Logic (C, B, A)
      const cButtons = document.querySelectorAll('.btn-toggle-level-c');
      const bButtons = document.querySelectorAll('.btn-toggle-level-b');
      const aButtons = document.querySelectorAll('.btn-toggle-level-a');
      const levelBadge = document.getElementById('header-level-badge');

      function setLevel(newLevel) {
        if (newLevel === 'A') {
          document.documentElement.classList.add('level-a');
          document.documentElement.classList.add('level-b');
          localStorage.setItem('math-level', 'A');
          
          cButtons.forEach(btn => btn.classList.remove('active'));
          bButtons.forEach(btn => btn.classList.remove('active'));
          aButtons.forEach(btn => btn.classList.add('active'));
          
          if (levelBadge) levelBadge.textContent = 'Matematik A';
        } else if (newLevel === 'B') {
          document.documentElement.classList.remove('level-a');
          document.documentElement.classList.add('level-b');
          localStorage.setItem('math-level', 'B');
          
          cButtons.forEach(btn => btn.classList.remove('active'));
          bButtons.forEach(btn => btn.classList.add('active'));
          aButtons.forEach(btn => btn.classList.remove('active'));
          
          if (levelBadge) levelBadge.textContent = 'Matematik B';
        } else {
          document.documentElement.classList.remove('level-a');
          document.documentElement.classList.remove('level-b');
          localStorage.setItem('math-level', 'C');
          
          cButtons.forEach(btn => btn.classList.add('active'));
          bButtons.forEach(btn => btn.classList.remove('active'));
          aButtons.forEach(btn => btn.classList.remove('active'));
          
          if (levelBadge) levelBadge.textContent = 'Matematik C';
        }
        window.dispatchEvent(new CustomEvent('clevermat_level_change', { detail: newLevel }));
      }

      // Initialize Level on Load
      const savedLevel = localStorage.getItem('math-level') || 'C';
      setLevel(savedLevel);

      // Event Listeners for Level Toggles
      cButtons.forEach(btn => btn.addEventListener('click', () => setLevel('C')));
      bButtons.forEach(btn => btn.addEventListener('click', () => setLevel('B')));
      aButtons.forEach(btn => btn.addEventListener('click', () => setLevel('A')));

      // Sidebar Collapsing/Expandable Modules Logic
      const modulesElements = document.querySelectorAll('.sidebar-module');
      modulesElements.forEach(mod => {
        const moduleId = mod.getAttribute('data-module-id');
        const toggleBtn = mod.querySelector('button');
        const list = mod.querySelector('.sidebar-module-list');
        const arrow = mod.querySelector('.sidebar-module-arrow');

        if (!moduleId || !toggleBtn || !list || !arrow) return;

        // Check if there is an active item inside this module
        const hasActiveChild = list.querySelector('a[href="' + window.location.pathname + '"]') !== null;

        // Restore saved collapsible state (default to collapsed if not set, unless it has active child)
        const savedState = localStorage.getItem(`collapsed_${moduleId}`);
        let isCollapsed = savedState === null ? true : savedState === 'true';
        
        if (hasActiveChild) {
          isCollapsed = false; // Always keep open if currently viewing its child topic
        }

        if (isCollapsed) {
          list.classList.add('collapsed');
          arrow.classList.add('collapsed');
        } else {
          list.classList.remove('collapsed');
          arrow.classList.remove('collapsed');
        }

        // Toggle state on click
        toggleBtn.addEventListener('click', () => {
          const wasCollapsed = list.classList.contains('collapsed');
          
          if (wasCollapsed) {
            // Collapse all other modules when expanding this one
            modulesElements.forEach(otherMod => {
              if (otherMod !== mod) {
                const otherList = otherMod.querySelector('.sidebar-module-list');
                const otherArrow = otherMod.querySelector('.sidebar-module-arrow');
                const otherId = otherMod.getAttribute('data-module-id');
                if (otherList && otherArrow && otherId) {
                  otherList.classList.add('collapsed');
                  otherArrow.classList.add('collapsed');
                  localStorage.setItem(`collapsed_${otherId}`, 'true');
                }
              }
            });
          }

          const currentlyCollapsed = list.classList.toggle('collapsed');
          arrow.classList.toggle('collapsed');
          localStorage.setItem(`collapsed_${moduleId}`, currentlyCollapsed ? 'true' : 'false');
        });
      });

      // Mobile / Desktop Sidebar Collapse Toggle
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const menuClose = document.getElementById('mobile-menu-close');
      const mobileSidebar = document.getElementById('mobile-sidebar');
      const overlay = document.getElementById('mobile-sidebar-overlay');

      function openSidebar() {
        mobileSidebar?.classList.remove('-translate-x-full');
        overlay?.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      }

      function closeSidebar() {
        mobileSidebar?.classList.add('-translate-x-full');
        overlay?.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }

      menuToggle?.addEventListener('click', () => {
        if (window.innerWidth >= 768) {
          // On Desktop, fold/unfold the sidebar completely
          document.documentElement.classList.toggle('sidebar-collapsed');
          localStorage.setItem('sidebar-collapsed', document.documentElement.classList.contains('sidebar-collapsed') ? 'true' : 'false');
        } else {
          // On Mobile, open the drawer overlay
          openSidebar();
        }
      });
      menuClose?.addEventListener('click', closeSidebar);
      overlay?.addEventListener('click', closeSidebar);

      // Auth Session Rendering in header
      const authStatusContainer = document.getElementById('auth-status-container');
      const sidebarUserFooter = document.getElementById('sidebar-user-footer');
      const mobileSidebarUserFooter = document.getElementById('mobile-sidebar-user-footer');
      function getLevelInfo(totalXP) {
        let level = 1;
        while (true) {
          let limit = 0;
          for (let i = 1; i < level + 1; i++) {
            limit += Math.floor(100 * Math.pow(i, 1.5));
          }
          if (totalXP < limit) break;
          level++;
        }

        let currentLevelStart = 0;
        for (let i = 1; i < level; i++) {
          currentLevelStart += Math.floor(100 * Math.pow(i, 1.5));
        }

        let nextLevelStart = currentLevelStart + Math.floor(100 * Math.pow(level, 1.5));
        
        const xpInCurrentLevel = totalXP - currentLevelStart;
        const xpNeededForNextLevel = nextLevelStart - currentLevelStart;
        const percent = Math.min(100, Math.max(0, (xpInCurrentLevel / xpNeededForNextLevel) * 100));

        return { level, currentLevelXP: xpInCurrentLevel, nextLevelXP: xpNeededForNextLevel, progressPercent: percent };
      }

      function renderAuthStatus() {
        const savedSession = localStorage.getItem('clevermat_session');
        let totalXp = 0;
        let isPremium = false;
        let userEmail = 'Gæstebruger';
        let initialLetters = 'G';

        if (savedSession) {
          try {
            const session = JSON.parse(savedSession);
            if (session.user) {
              userEmail = session.user.email;
              totalXp = session.user.xp || 0;
              isPremium = session.user.membershipType === 'PREMIUM';
              initialLetters = userEmail.substring(0, 2).toUpperCase();

              if (authStatusContainer) {
                authStatusContainer.innerHTML = `
                  <div class="flex items-center gap-3">
                    <div class="text-right">
                      <a href="/profile" class="text-xs font-semibold text-slate-600 hover:text-brand-600 dark:text-slate-300 dark:hover:text-brand-400 max-w-[120px] truncate block transition-colors">${userEmail}</a>
                    </div>
                    <button id="auth-signout-btn" class="text-xs text-slate-555 hover:text-red-500 dark:text-slate-350 dark:hover:text-red-400 font-bold px-2 py-1 rounded transition-colors cursor-pointer">Log ud</button>
                  </div>
                `;

                document.getElementById('auth-signout-btn')?.addEventListener('click', () => {
                  localStorage.removeItem('clevermat_session');
                  renderAuthStatus();
                  window.location.href = '/';
                });
              }

              // Render sidebar footers
              const footerHtml = `
                <div class="flex items-center justify-between gap-2 p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-900/60 transition-colors">
                  <a href="/profile" class="flex items-center gap-3 min-w-0 flex-1 group">
                    <div class="h-9 w-9 rounded-xl bg-gradient-to-tr ${isPremium ? 'from-amber-500 to-yellow-400 text-slate-950 shadow shadow-amber-500/20' : 'from-brand-600 to-sky-400 text-white shadow shadow-brand-500/20'} flex items-center justify-center font-bold font-outfit text-sm shrink-0">
                      ${initialLetters}
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="text-xs font-bold text-slate-850 dark:text-slate-200 truncate group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors">${userEmail}</div>
                      <div class="flex items-center gap-1 mt-0.5">
                        ${isPremium 
                          ? `<span class="text-[9px] font-extrabold px-1.5 py-0.5 rounded bg-gradient-to-tr from-amber-500 to-yellow-400 text-slate-950 border border-amber-300">PREMIUM</span>` 
                          : `<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 dark:bg-slate-900 dark:text-slate-400 border border-slate-200/20 dark:border-slate-800/20">GRATIS</span>`
                        }
                      </div>
                    </div>
                  </a>
                </div>
              `;

              if (sidebarUserFooter) sidebarUserFooter.innerHTML = footerHtml;
              if (mobileSidebarUserFooter) mobileSidebarUserFooter.innerHTML = footerHtml;
            }
          } catch (e) {
            console.error('Error parsing session in header', e);
          }
        } else {
          // Guest mode
          totalXp = parseInt(localStorage.getItem('clevermat_local_xp') || '0', 10);
          
          if (authStatusContainer) {
            authStatusContainer.innerHTML = `
              <a href="/login" class="text-sm font-semibold text-slate-700 dark:text-slate-300 hover:text-brand-600 dark:hover:text-brand-400 bg-slate-100 hover:bg-slate-200 dark:bg-slate-900 dark:hover:bg-slate-800 px-3.5 py-1.5 rounded-lg transition-all">Log ind</a>
            `;
          }

          const promoHtml = `
            <div class="p-3 rounded-xl bg-gradient-to-tr from-brand-600/5 to-sky-500/5 border border-brand-500/10 dark:border-brand-500/5 text-center">
              <p class="text-xs text-slate-550 dark:text-slate-400 mb-2 font-medium">Gem dine fremskridt & optjen XP</p>
              <a href="/login" class="block w-full text-center text-xs font-bold py-2 px-3 rounded-lg bg-gradient-to-tr from-brand-600 to-sky-500 text-white hover:shadow-lg hover:shadow-brand-500/25 transition-all">Log ind / Opret</a>
            </div>
          `;
          if (sidebarUserFooter) sidebarUserFooter.innerHTML = promoHtml;
          if (mobileSidebarUserFooter) mobileSidebarUserFooter.innerHTML = promoHtml;
        }

        const sprintCard = document.getElementById('sidebar-cleversprint-card');
        if (sprintCard) {
          if (isPremium) {
            sprintCard.classList.add('hidden');
          } else {
            sprintCard.classList.remove('hidden');
          }
        }
      }

      renderAuthStatus();

      // Listen for auth change events
      window.addEventListener('clevermat_auth_change', renderAuthStatus);

      // List of quizzes per slug to calculate total XP and current progress
      const quizzesBySlug = {
        'analytisk-plangeometri/afstande': [
