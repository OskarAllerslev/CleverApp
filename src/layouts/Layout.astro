      { slug: 'funktioner/lineaere-funktioner', title: 'Lineære Funktioner' },
      { slug: 'funktioner/andengradspolynomier', title: 'Andengradspolynomier' },
      { slug: 'funktioner/eksponentiel-og-potens', title: 'Eksponentiel & Potens' },
      { slug: 'funktioner/regression', title: 'Regression' },
    ]
  },
  {
    title: 'Statistik og Sandsynlighed',
    slug: 'statistik-og-sandsynlighed',
    level: 'C',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    items: [
