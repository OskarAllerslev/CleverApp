      { slug: 'matematik-a/avanceret-infinitesimalregning/omdrejningslegemer', title: 'Omdrejningslegemer' },
    ]
  },
  {
    title: 'Differentialligninger',
    slug: 'differentialligninger',
    level: 'A',
    icon: 'M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
    items: [
      { slug: 'matematik-a/differentialligninger/opstilling-af-modeller', title: 'Modelopstilling' },
      { slug: 'matematik-a/differentialligninger/separationsmetoden', title: 'Separation af Variable' },
      { slug: 'matematik-a/differentialligninger/logistisk-vaekst', title: 'Logistisk Vækst' },
      { slug: 'matematik-a/differentialligninger/eulers-metode', title: 'Eulers Metode' },
    ]
  },
  {
    title: 'Statistik & Sandsynlighed (A)',
    slug: 'avanceret-statistik-og-sandsynlighed',
    level: 'A',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2',
    items: [
      { slug: 'matematik-a/avanceret-statistik-og-sandsynlighed/normalfordeling-taethed', title: 'Normalfordeling' },
      { slug: 'matematik-a/avanceret-statistik-og-sandsynlighed/intervalsandsynlighed', title: 'Intervalsandsynlighed' },
    ]
  }
];

// Helper to determine active state
const isActive = (itemSlug: string) => currentSlug === itemSlug;

// Find next and previous topics for navigation buttons
const allItems = modules.flatMap(m => m.items);
const currentIndex = allItems.findIndex(item => item.slug === currentSlug);
const prevItem = currentIndex > 0 ? allItems[currentIndex - 1] : null;
const nextItem = currentIndex !== -1 && currentIndex < allItems.length - 1 ? allItems[currentIndex + 1] : null;

// Sidebar layout determination (Scenario A vs B)
const isDocsPage = Astro.url.pathname.startsWith('/docs/');

const activeModule = isDocsPage
  ? modules.find(mod => mod.items.some(item => Astro.url.pathname.includes(item.slug) || (currentSlug && currentSlug === item.slug)))
  : null;

const proofsBySlug = {
  'tal-og-algebra': [
    { title: 'Brøkregneregler', desc: 'Regneregler for brøker', anchor: '/docs/tal-og-algebra/broeker#4-multiplikation-og-division-de-hurtige-regneregler' },
    { title: 'Procentregning', desc: 'Vækst og renteformler', anchor: '/docs/tal-og-algebra/procent-og-rente#teori-renteformlen' }
  ],
  'geometri-og-trigonometri': [
    { title: 'Pythagoras Sætning', desc: 'Geometrisk bevis', anchor: '/docs/geometri-og-trigonometri/pythagoras#teori-pythagoras-sætning' },
    { title: 'Cosinusrelationerne', desc: 'Formler for vilkårlige trekanter', anchor: '/docs/geometri-og-trigonometri/trekantsberegninger#teori-cosinusrelationerne' }
  ],
  'funktioner': [
    { title: 'To-punkts-formlen', desc: 'Bevis for lineær hældning a og b', anchor: '/docs/funktioner/lineaere-funktioner#teori-to-punkts-formlen' },
    { title: 'Eksponentielle konstanter', desc: 'Bevis for a og b i y = b * a^x', anchor: '/docs/funktioner/eksponentiel-og-potens#teori-fordoblings-og-halveringskonstant' }
  ],
  'statistik-og-sandsynlighed': [
    { title: 'Ugrupperet Data', desc: 'Deskriptorer og kvartiler', anchor: '/docs/statistik-og-sandsynlighed/ugrupperet-data#teori-hyppighed-og-frekvens' },
    { title: 'Kombinatorik', desc: 'Kombinationer og permutationer', anchor: '/docs/statistik-og-sandsynlighed/kombinatorik#teori-kombinationer--knr' }
  ],
  'analytisk-plangeometri': [
    { title: 'Afstandsformel', desc: 'Punkt til linje i planen', anchor: '/docs/analytisk-plangeometri/afstande#teori-afstand-fra-punkt-til-linje' },
    { title: 'Cirklens ligning', desc: 'Udledning via afstand til centrum', anchor: '/docs/analytisk-plangeometri/cirklens-ligning#teori-cirklens-ligning--standardform' }
  ],
  'infinitesimalregning': [
    { title: 'Tretrinsreglen', desc: 'Bevis for differentialkvotient', anchor: '/docs/infinitesimalregning/tretrinsreglen#teori-tretrinsreglens-3-trin' }
  ],
  'avanceret-statistik': [
    { title: 'Sandsynlighedsfunktion', desc: 'Binomialfordeling P(X=k)', anchor: '/docs/avanceret-statistik/binomialfordeling#teori-sandsynlighedsfunktionen-pxk' }
  ],
  'vektorer-og-analytisk-geometri': [
    { title: 'Kuglens ligning', desc: 'Standardform i 3D rummet', anchor: '/docs/matematik-a/vektorer-og-analytisk-geometri/kuglens-ligning#teori-kuglens-ligning--standardform' },
    { title: 'Afstand i rummet', desc: 'Punkt til plan afstandsformel', anchor: '/docs/matematik-a/vektorer-og-analytisk-geometri/afstande#teori-afstand-fra-punkt-til-plan-i-3d' }
  ],
  'avanceret-infinitesimalregning': [
    { title: 'Substitution', desc: 'Bevis for ubestemt integral', anchor: '/docs/matematik-a/avanceret-infinitesimalregning/substitution#teori-integraler-med-substitution' },
    { title: 'Omdrejningslegemer', desc: 'Volumenformel bevis', anchor: '/docs/matematik-a/avanceret-infinitesimalregning/omdrejningslegemer#teori-omdrejningslegeme-om-x-aksen' }
  ],
  'differentialligninger': [
    { title: 'Separation af variable', desc: 'Bevis for løsningsformel', anchor: '/docs/matematik-a/differentialligninger/separationsmetoden#teori-separationsmetoden' },
    { title: 'Logistisk vækst', desc: 'Udledning af løsning', anchor: '/docs/matematik-a/differentialligninger/logistisk-vaekst#teori-den-logistiske-differentialligning' }
  ],
  'avanceret-statistik-og-sandsynlighed': [
    { title: 'Normalfordeling', desc: 'Tæthedsfunktion under klokkekurven', anchor: '/docs/matematik-a/avanceret-statistik-og-sandsynlighed/normalfordeling-taethed#teori-normalfordelingens-tæthedsfunktion' }
  ]
};

const getBadgeClass = (level: string) => {
  if (level === 'C') {
    return 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 dark:border-emerald-400/20';
  } else if (level === 'B') {
    return 'bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20 dark:border-blue-400/20';
  } else {
    return 'bg-gradient-to-r from-purple-500/10 to-amber-500/10 text-purple-600 dark:text-purple-400 border border-amber-500/30 dark:border-amber-400/30';
  }
};
---

<!DOCTYPE html>
<html lang="da" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | CleverMat</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts: Outfit and Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Inline script to prevent theme, level, and sidebar flashing -->
    <script is:inline>
      // Auth Guard & Sidebar hiding
      if (typeof localStorage !== 'undefined') {
        const session = localStorage.getItem('clevermat_session');
        const isLoginPage = window.location.pathname === '/login';
        const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index.html';
        
        if (!session) {
          document.documentElement.classList.add('no-sidebar');
          if (!isLoginPage && !isHomePage && !window.location.pathname.startsWith('/premium/terp')) {
            window.location.href = '/login';
          }
        } else {
          document.documentElement.classList.remove('no-sidebar');
          try {
            const parsed = JSON.parse(session);
            if (parsed?.user?.membershipType !== 'PREMIUM' && window.location.pathname.startsWith('/premium') && !window.location.pathname.startsWith('/premium/terp')) {
              window.location.href = '/';
            }
          } catch (e) {
            console.error('Auth guard error', e);
          }
        }
      }

      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      window.localStorage.setItem('theme', theme);

      const level = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('math-level')) {
          return localStorage.getItem('math-level');
        }
        return 'C';
      })();
      if (level === 'A') {
        document.documentElement.classList.add('level-a');
        document.documentElement.classList.add('level-b');
      } else if (level === 'B') {
        document.documentElement.classList.add('level-b');
        document.documentElement.classList.remove('level-a');
      } else {
        document.documentElement.classList.remove('level-a');
        document.documentElement.classList.remove('level-b');
      }
      window.localStorage.setItem('math-level', level);

      const sidebarCollapsed = typeof localStorage !== 'undefined' && localStorage.getItem('sidebar-collapsed') === 'true';
      if (sidebarCollapsed && window.innerWidth >= 768) {
        document.documentElement.classList.add('sidebar-collapsed');
      }
    </script>
    <style is:global>
      html.no-sidebar #desktop-sidebar {
        display: none !important;
      }
      html.no-sidebar #mobile-menu-toggle {
        display: none !important;
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100 flex flex-col min-h-screen">
    <!-- Navbar / Header -->
    <header class="sticky top-0 z-40 w-full border-b border-slate-200/80 bg-white/80 dark:border-slate-800/80 dark:bg-slate-950/80 backdrop-blur-md transition-colors duration-200">
      <div class="flex h-16 w-full items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3">
          <!-- Sidebar Toggle (Desktop collapse, Mobile modal drawer) -->
          <button id="mobile-menu-toggle" type="button" class="inline-flex items-center justify-center rounded-md p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-500 dark:text-slate-400 dark:hover:bg-slate-900 dark:hover:text-slate-100 cursor-pointer" aria-label="Fold navigation">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
          
          <a href="/" class="flex items-center gap-2 group">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-tr from-brand-600 to-sky-400 text-white font-outfit font-bold text-xl shadow-md shadow-brand-500/20 group-hover:scale-105 transition-transform duration-200">
              C
            </div>
            <span class="font-outfit font-bold text-xl tracking-tight bg-gradient-to-r from-brand-600 to-sky-500 bg-clip-text text-transparent dark:from-brand-400 dark:to-sky-400">
              CleverMat
            </span>
            <span id="header-level-badge" class="rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold text-brand-700 dark:bg-brand-900/60 dark:text-brand-300">
              Matematik C
            </span>
          </a>
        </div>

        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600 dark:text-slate-300">
          <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Hjem / Dashboard</a>
          <a href="/docs/tal-og-algebra/regningsarter" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Læringssti</a>
          <a href="/premium/terp" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors flex items-center gap-1.5 font-bold">
            <span>CleverSprint</span>
            <span class="text-[9px] font-extrabold px-1.5 py-0.5 rounded-full bg-gradient-to-tr from-amber-500 to-yellow-400 text-slate-950 shadow-sm border border-amber-300">PREMIUM</span>
          </a>
        </nav>

        <div class="flex items-center gap-4">
          <!-- Level Progress Bar -->
          <div class="hidden lg:block w-72">
            <LevelProgressBar client:load />
          </div>

          <!-- Auth session status/action -->
          <div id="auth-status-container" class="flex items-center gap-2">
            <a href="/login" class="text-sm font-semibold text-slate-700 dark:text-slate-300 hover:text-brand-600 dark:hover:text-brand-400 bg-slate-100 hover:bg-slate-200 dark:bg-slate-900 dark:hover:bg-slate-800 px-3.5 py-1.5 rounded-lg transition-all">Log ind</a>
          </div>

          <!-- Interactive Theme Slider -->
          <button 
            id="theme-toggle" 
            type="button" 
            class="group relative w-14 h-7 rounded-full p-0.5 bg-gradient-to-r from-sky-300 to-sky-400 dark:from-indigo-950 dark:via-slate-900 dark:to-blue-950 border border-sky-200/40 dark:border-indigo-900/40 shadow-inner cursor-pointer overflow-hidden transition-all duration-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50 select-none shrink-0"
            aria-label="Skift tema"
          >
            <!-- Twinkling stars (visible only in dark mode) -->
            <div class="absolute inset-0 opacity-0 dark:opacity-100 transition-opacity duration-500 pointer-events-none">
              <span class="absolute top-1.5 left-2 w-0.5 h-0.5 bg-white rounded-full opacity-80"></span>
              <span class="absolute top-4 left-4 w-0.5 h-0.5 bg-white rounded-full opacity-40"></span>
              <span class="absolute top-2 left-6 w-0.5 h-0.5 bg-white rounded-full opacity-60"></span>
            </div>

            <!-- Fluffy Clouds (visible only in light mode) -->
            <div class="absolute inset-0 opacity-100 dark:opacity-0 transition-opacity duration-500 pointer-events-none">
              <svg class="absolute top-1.5 right-1.5 h-3.5 w-5 text-white/80 filter drop-shadow-sm" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19.36 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.64-4.96z" />
              </svg>
            </div>

            <!-- Slider Knob (Thumb) -->
            <div 
              id="theme-slider-thumb"
              class="relative w-[22px] h-[22px] rounded-full flex items-center justify-center transition-all duration-500 transform translate-x-0 dark:translate-x-7 bg-white dark:bg-slate-900 shadow-md border border-amber-200 dark:border-slate-800 shrink-0"
            >
              <!-- Sun Icon (Active in Light mode) -->
