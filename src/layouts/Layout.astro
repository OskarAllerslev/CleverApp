                      </a>
                    </li>
                  ))}
                </ul>

                {/* Proofs links mapping */}
                {(() => {
                  const proofs = proofsBySlug[activeModule.slug] || [];
                  if (proofs.length === 0) return null;
                  return (
                    <div class="pt-4 border-t border-slate-150 dark:border-slate-800 space-y-2.5">
                      <span class="text-[9px] font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 block">Centrale Beviser</span>
