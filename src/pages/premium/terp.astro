---
import Layout from '../../layouts/Layout.astro';
import CleverSprint from '../../components/CleverSprint.tsx';
import prisma from '../../lib/db/client';
import { verifySession } from '../../lib/db/auth-server';

export const prerender = false;

const sessionToken = Astro.cookies.get('clevermat_session')?.value;
const userId = verifySession(sessionToken);

let membershipType = 'GUEST';

if (userId) {
  const user = await prisma.user.findUnique({
    where: { id: userId },
    select: { membershipType: true },
  });
  if (user) {
    membershipType = user.membershipType;
  }
}
---

<Layout title="CleverSprint - Spaced Repetition Terpning">
  <div class="flex-1 flex flex-col justify-start relative max-w-4xl mx-auto w-full py-8">
    <!-- Premium background decorations -->
    <div class="absolute inset-0 -z-10 flex items-center justify-center opacity-10 dark:opacity-10 blur-3xl pointer-events-none">
      <div class="h-[500px] w-[500px] rounded-full bg-amber-500"></div>
      <div class="h-[400px] w-[400px] rounded-full bg-brand-500 -ml-40"></div>
    </div>

    <!-- Active CleverSprint Component -->
    <CleverSprint client:load membershipType={membershipType} />
  </div>
</Layout>
