---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { overview, goals, intuition, level, title } = entry.data;

// Determine level badge colors
const levelBadgeClass = level?.includes('A') 
  ? 'bg-purple-500/10 text-purple-700 dark:text-purple-300 border border-purple-400/20'
  : level?.includes('B')
    ? 'bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-400/20'
    : 'bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 border border-emerald-400/20';

const levelIcon = level?.includes('A') ? '🔮' : level?.includes('B') ? '📘' : '🌱';
---

<Layout title={entry.data.title} description={entry.data.description} currentSlug={entry.id}>
  <div class="relative w-full max-w-4xl">
    
    <!-- Top badge/metadata -->
    <div class="mb-4 flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 font-medium">
      <span>{entry.data.level}</span>
      <span>•</span>
      <span class="text-brand-600 dark:text-brand-400 capitalize">
        {entry.id.split('/')[0].replace(/-/g, ' ')}
      </span>
    </div>

    <!-- Overview Card (shown if any overview metadata exists) -->
    {(overview || goals || intuition) && (
      <div class="mb-8 rounded-2xl border border-brand-200/60 dark:border-brand-800/40 bg-gradient-to-br from-brand-50/80 to-sky-50/50 dark:from-slate-900/80 dark:to-slate-950/60 p-5 md:p-6 shadow-sm relative overflow-hidden">
        {/* Decorative background blob */}
        <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-brand-400/5 dark:bg-brand-600/5 blur-2xl pointer-events-none"></div>
        
        {/* Header row */}
        <div class="flex items-center gap-2.5 mb-3.5">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white text-sm shadow-sm shadow-brand-500/20 shrink-0">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <div>
            <span class="text-[10px] font-extrabold uppercase tracking-widest text-brand-600 dark:text-brand-400 block leading-none">Kapitel Overblik</span>
            <span class="text-xs font-semibold text-slate-600 dark:text-slate-400">{title}</span>
          </div>
          <span class={`ml-auto text-[10px] font-extrabold px-2 py-0.5 rounded-full ${levelBadgeClass} shrink-0`}>
            {levelIcon} {level}
          </span>
        </div>

        {/* Overview text */}
        {overview && (
          <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed mb-4 font-medium">
            {overview}
          </p>
        )}

        {/* Goals list */}
        {goals && goals.length > 0 && (
          <div class="mb-4">
            <span class="text-[10px] font-extrabold uppercase tracking-wider text-brand-600 dark:text-brand-400 block mb-2">Du lærer at:</span>
            <ul class="space-y-1.5">
              {goals.map((goal) => (
                <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300">
                  <svg class="h-4 w-4 text-brand-500 dark:text-brand-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span>{goal}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Intuition callout */}
        {intuition && (
          <div class="flex items-start gap-2.5 pt-3.5 border-t border-brand-200/50 dark:border-brand-800/30">
            <span class="text-lg shrink-0 leading-none mt-0.5">💡</span>
            <div>
              <span class="text-[10px] font-extrabold uppercase tracking-wider text-amber-600 dark:text-amber-400 block mb-0.5">Intuitionen</span>
              <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed italic">"{intuition}"</p>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- Main visual article -->
    <article class="prose prose-slate dark:prose-invert max-w-none lg:prose-lg 
      prose-headings:font-outfit prose-headings:font-bold prose-headings:tracking-tight
      prose-h1:text-4xl prose-h1:md:text-5xl prose-h1:text-slate-900 dark:prose-h1:text-white
      prose-h2:text-2xl prose-h2:md:text-3xl prose-h2:text-slate-800 dark:prose-h2:text-slate-100 prose-h2:mt-10
      prose-p:text-slate-600 dark:prose-p:text-slate-300 prose-p:leading-relaxed
      prose-a:text-brand-600 dark:prose-a:text-brand-400 prose-a:no-underline hover:prose-a:underline
      prose-strong:text-slate-900 dark:prose-strong:text-white
      prose-ol:list-decimal prose-ul:list-disc
      prose-code:text-brand-600 dark:prose-code:text-brand-400 prose-code:bg-brand-50/50 dark:prose-code:bg-brand-950/20 
      prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-semibold
      prose-code:before:content-none prose-code:after:content-none">
      <Content />
    </article>

  </div>
</Layout>
