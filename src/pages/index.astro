  <!-- Interactive script for level dashboard syncing -->
  <script>
    // Toggle guest CTA banner based on login state
    const session = localStorage.getItem('clevermat_session');
    if (!session) {
      document.getElementById('guest-cta-banner')?.classList.remove('hidden');
    }

    // Dashboard Level Button Syncing Logic (Mat C, B, A)
    const dashCButtons = document.querySelectorAll('.btn-toggle-level-c');
    const dashBButtons = document.querySelectorAll('.btn-toggle-level-b');
    const dashAButtons = document.querySelectorAll('.btn-toggle-level-a');

    function updateDashboardButtons(currentLevel) {
      if (currentLevel === 'A') {
        dashCButtons.forEach(btn => btn.className = 'btn-toggle-level-c px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer');
        dashBButtons.forEach(btn => btn.className = 'btn-toggle-level-b px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer');
        dashAButtons.forEach(btn => btn.className = 'btn-toggle-level-a px-6 py-2.5 rounded-xl font-bold text-sm border border-brand-500 bg-brand-500 text-white shadow-md shadow-brand-500/25 transition-all duration-200 cursor-pointer');
      } else if (currentLevel === 'B') {
        dashCButtons.forEach(btn => btn.className = 'btn-toggle-level-c px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer');
        dashBButtons.forEach(btn => btn.className = 'btn-toggle-level-b px-6 py-2.5 rounded-xl font-bold text-sm border border-brand-500 bg-brand-500 text-white shadow-md shadow-brand-500/25 transition-all duration-200 cursor-pointer');
        dashAButtons.forEach(btn => btn.className = 'btn-toggle-level-a px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer');
      } else {
        dashCButtons.forEach(btn => btn.className = 'btn-toggle-level-c px-6 py-2.5 rounded-xl font-bold text-sm border border-brand-500 bg-brand-500 text-white shadow-md shadow-brand-500/25 transition-all duration-200 cursor-pointer');
        dashBButtons.forEach(btn => btn.className = 'btn-toggle-level-b px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer');
        dashAButtons.forEach(btn => btn.className = 'btn-toggle-level-a px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer');
      }
    }

    // Initialize Dashboard Level UI on Load
    const activeLevel = localStorage.getItem('math-level') || 'C';
    updateDashboardButtons(activeLevel);

    // Sync button states when level changes elsewhere (e.g. from sidebar)
    window.addEventListener('clevermat_level_change', (e) => {
      updateDashboardButtons(e.detail);
    });
  </script>
