---
import Layout from '../layouts/Layout.astro';
import { HeroTangentVisualizer } from '../components/visualizers/HeroTangentVisualizer.tsx';
---

<Layout title="Forstå Matematik Visuelt">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-12 md:py-20 lg:py-24">
    <!-- Background glow decoration -->
    <div class="absolute inset-0 -z-10 flex items-center justify-center opacity-30 dark:opacity-20 blur-3xl pointer-events-none">
      <div class="h-96 w-96 rounded-full bg-brand-500"></div>
      <div class="h-80 w-80 rounded-full bg-sky-400 -ml-20"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Text content -->
      <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-sm font-semibold text-brand-700 dark:bg-brand-950/60 dark:text-brand-300">
          <span class="h-2 w-2 rounded-full bg-brand-500 animate-pulse"></span>
          Gymnasial Læringsplatform
        </div>
        <h1 class="font-outfit text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
          Forstå matematik helt ind til <span class="bg-gradient-to-r from-brand-600 to-sky-500 bg-clip-text text-transparent dark:from-brand-400 dark:to-sky-400">kernen</span>
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
          Glem alt om tør udenadslære. Lær Matematik C, B og A gennem interaktive visualiseringer, intuitive forklaringer og opgaver, der vækker din matematiske sans og styrker din logiske tænkning.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-2">
          <a
            href="/docs/tal-og-algebra/regningsarter"
            class="inline-flex items-center justify-center rounded-xl bg-gradient-to-tr from-brand-600 to-sky-500 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-500/25 hover:shadow-brand-500/45 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 group"
          >
            Start læring nu
            <svg class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="#curriculum"
            class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white/60 px-6 py-3.5 text-base font-semibold text-slate-700 hover:bg-slate-50 hover:text-slate-900 dark:border-slate-800 dark:bg-slate-900/60 dark:text-slate-300 dark:hover:bg-slate-900 transition-all duration-200"
          >
            Se pensum
          </a>
        </div>
      </div>

      <!-- Hero Visual (Interactive SVG Coordinate Plane) -->
      <div class="lg:col-span-5 flex justify-center">
        <HeroTangentVisualizer client:load />
      </div>
    </div>
  </section>

  <!-- Guest CTA Section -->
  <section id="guest-cta-banner" class="hidden max-w-4xl mx-auto w-full px-4 sm:px-6 lg:px-8 mb-12">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-brand-600 to-sky-500 p-8 md:p-12 shadow-xl text-white">
      <!-- background glows -->
      <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-white/10 blur-2xl"></div>
      <div class="absolute -left-10 -bottom-10 h-40 w-40 rounded-full bg-white/10 blur-2xl"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="space-y-3 text-center md:text-left max-w-lg">
          <span class="inline-flex items-center gap-1 rounded-full bg-white/20 px-3 py-1 text-xs font-extrabold uppercase tracking-wider text-white">
            100% Gratis Adgang 🎁
          </span>
          <h2 class="font-outfit text-2xl md:text-3xl font-black tracking-tight leading-tight">
            Lås op for alle interaktive emner, visualiseringer og opgavesæt!
          </h2>
          <p class="text-white/80 text-sm leading-relaxed">
            Opret din gratis profil i dag for at få fuld adgang til al teori, interaktiv feedback og fremskridts-tracking på tværs af Mat C, B og A.
          </p>
        </div>
        <div class="shrink-0 w-full md:w-auto text-center">
          <a href="/login" class="inline-flex w-full md:w-auto items-center justify-center rounded-2xl bg-white px-8 py-4 text-base font-black text-slate-950 shadow-lg hover:bg-slate-50 hover:scale-105 active:scale-95 transition-all duration-200">
            Opret bruger og få hjælp til alt matematik gratis 🚀
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Curriculum Grid Section -->
  <section id="curriculum" class="py-12 space-y-10">
    <div class="text-center space-y-3">
      <h2 class="font-outfit text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">
        Udforsk læreplanerne
      </h2>
      <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Vores pensum følger de officielle danske gymnasiale retningslinjer for Matematik C, B og A.
      </p>
    </div>

    <!-- Switch Level on Dashboard (C, B, A) -->
    <div class="flex justify-center gap-4 my-2">
      <button class="btn-toggle-level-c px-6 py-2.5 rounded-xl font-bold text-sm border border-brand-500 bg-brand-500 text-white shadow-md shadow-brand-500/25 transition-all duration-200 cursor-pointer">
        Vis Matematik C
      </button>
      <button class="btn-toggle-level-b px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer">
        Vis Matematik B
      </button>
      <button class="btn-toggle-level-a px-6 py-2.5 rounded-xl font-bold text-sm border border-slate-200 bg-white text-slate-600 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 cursor-pointer">
        Vis Matematik A
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Module 1 (C-level) -->
      <div class="group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-brand-500/50 dark:hover:border-brand-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-950/60 dark:text-brand-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Tal og Algebra</h3>
              <span class="text-[10px] font-bold bg-brand-100 text-brand-700 dark:bg-brand-900/60 dark:text-brand-300 px-1.5 py-0.5 rounded">Mat C</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Håndtering af regneregler, ligninger, potenser og procenter.</p>
          </div>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300 pt-2 border-t border-slate-100 dark:border-slate-800">
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span> Regningsarter</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span> Brøkregning</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span> Ligninger & formler</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span> Potenser og rødder</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span> Procent og rente</li>
          </ul>
        </div>
        <div class="pt-6">
          <a
            href="/docs/tal-og-algebra/regningsarter"
            class="flex items-center justify-center w-full rounded-xl bg-slate-100 py-3 text-sm font-semibold text-slate-700 hover:bg-brand-600 hover:text-white dark:bg-slate-800 dark:text-slate-350 dark:hover:bg-brand-600 dark:hover:text-white transition-all duration-200"
          >
            Start modul
          </a>
        </div>
      </div>

      <!-- Module 2 (C-level) -->
      <div class="group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-emerald-500/50 dark:hover:border-emerald-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 dark:bg-emerald-950/60 dark:text-emerald-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 19.5A2.5 2.5 0 016.5 17H20M4 19.5A2.5 2.5 0 006.5 22H20M4 19.5V3a1 1 0 011-1h13a1 1 0 011 1v16.5m-16 0h16M14 6h-4v4h4V6z" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Geometri & Trigonometri</h3>
              <span class="text-[10px] font-bold bg-brand-100 text-brand-700 dark:bg-brand-900/60 dark:text-brand-300 px-1.5 py-0.5 rounded">Mat C</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Beregning af sider, vinkler, trekanter og figursammenhænge.</p>
          </div>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300 pt-2 border-t border-slate-100 dark:border-slate-800">
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Ensvinklede trekanter</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Pythagoras' læresætning</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Sinus, cosinus og tangens</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Vilkårlige trekanter</li>
          </ul>
        </div>
        <div class="pt-6">
          <a
            href="/docs/geometri-og-trigonometri/ensvinklede-trekanter"
            class="flex items-center justify-center w-full rounded-xl bg-slate-100 py-3 text-sm font-semibold text-slate-700 hover:bg-emerald-600 hover:text-white dark:bg-slate-800 dark:text-slate-350 dark:hover:bg-emerald-600 dark:hover:text-white transition-all duration-200"
          >
            Start modul
          </a>
        </div>
      </div>

      <!-- Module 3 (C-level) -->
      <div class="group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-purple-500/50 dark:hover:border-purple-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-50 text-purple-600 dark:bg-purple-950/60 dark:text-purple-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Funktioner</h3>
              <span class="text-[10px] font-bold bg-brand-100 text-brand-700 dark:bg-brand-900/60 dark:text-brand-300 px-1.5 py-0.5 rounded">Mat C</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Det matematiske funktionsbegreb samt de klassiske vækstmodeller.</p>
          </div>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300 pt-2 border-t border-slate-100 dark:border-slate-800">
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> Funktionsbegrebet</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> Lineære funktioner</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> Andengradspolynomier</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> Eksponentiel & potens</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-purple-500"></span> Regression</li>
          </ul>
        </div>
        <div class="pt-6">
          <a
            href="/docs/funktioner/funktionsbegrebet"
            class="flex items-center justify-center w-full rounded-xl bg-slate-100 py-3 text-sm font-semibold text-slate-700 hover:bg-purple-600 hover:text-white dark:bg-slate-800 dark:text-slate-350 dark:hover:bg-purple-600 dark:hover:text-white transition-all duration-200"
          >
            Start modul
          </a>
        </div>
      </div>

      <!-- Module 4 (C-level) -->
      <div class="group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-orange-500/50 dark:hover:border-orange-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-orange-50 text-orange-600 dark:bg-orange-950/60 dark:text-orange-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Statistik & Sandsynlighed</h3>
              <span class="text-[10px] font-bold bg-brand-100 text-brand-700 dark:bg-brand-900/60 dark:text-brand-300 px-1.5 py-0.5 rounded">Mat C</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Udforskning af statistiske deskriptorer, intervaller og chancerelationer.</p>
          </div>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300 pt-2 border-t border-slate-100 dark:border-slate-800">
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span> Ugrupperet data</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span> Grupperet data</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span> Sandsynlighedsfelter</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span> Kombinatorik</li>
          </ul>
        </div>
        <div class="pt-6">
          <a
            href="/docs/statistik-og-sandsynlighed/ugrupperet-data"
            class="flex items-center justify-center w-full rounded-xl bg-slate-100 py-3 text-sm font-semibold text-slate-700 hover:bg-orange-600 hover:text-white dark:bg-slate-800 dark:text-slate-350 dark:hover:bg-orange-600 dark:hover:text-white transition-all duration-200"
          >
            Start modul
          </a>
        </div>
      </div>

      <!-- Module 5 (B-level - Hidden on Mat C) -->
      <div class="b-level-only group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-cyan-500/50 dark:hover:border-cyan-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-600 dark:bg-cyan-950/60 dark:text-cyan-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Analytisk Plangeometri</h3>
              <span class="text-[10px] font-bold bg-brand-100 text-brand-700 dark:bg-brand-900/60 dark:text-brand-300 px-1.5 py-0.5 rounded">Mat B</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Koordinatgeometri, linjens og cirklens ligninger samt geometriske afstande.</p>
          </div>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300 pt-2 border-t border-slate-100 dark:border-slate-800">
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-cyan-500"></span> Linjens ligning</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-cyan-500"></span> Cirklens ligning</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-cyan-500"></span> Afstande i planen</li>
          </ul>
        </div>
        <div class="pt-6">
          <a
            href="/docs/analytisk-plangeometri/linjens-ligning"
            class="flex items-center justify-center w-full rounded-xl bg-slate-100 py-3 text-sm font-semibold text-slate-700 hover:bg-cyan-600 hover:text-white dark:bg-slate-800 dark:text-slate-350 dark:hover:bg-cyan-600 dark:hover:text-white transition-all duration-200"
          >
            Start modul
          </a>
        </div>
      </div>

      <!-- Module 6 (B-level - Hidden on Mat C) -->
      <div class="b-level-only group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-indigo-500/50 dark:hover:border-indigo-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 dark:bg-indigo-950/60 dark:text-indigo-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h3 class="font-outfit text-xl font-bold text-slate-900 dark:text-white">Infinitesimalregning</h3>
              <span class="text-[10px] font-bold bg-brand-100 text-brand-700 dark:bg-brand-900/60 dark:text-brand-300 px-1.5 py-0.5 rounded">Mat B</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Differentiabilitet, differentialkvotient, tretrinsreglen og optimering.</p>
          </div>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300 pt-2 border-t border-slate-100 dark:border-slate-800">
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span> Differentialkvotient</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span> Tretrinsreglen</li>
            <li class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span> Monotoni & optimering</li>
          </ul>
        </div>
        <div class="pt-6">
          <a
            href="/docs/infinitesimalregning/differentialkvotient"
            class="flex items-center justify-center w-full rounded-xl bg-slate-100 py-3 text-sm font-semibold text-slate-700 hover:bg-indigo-600 hover:text-white dark:bg-slate-800 dark:text-slate-350 dark:hover:bg-indigo-600 dark:hover:text-white transition-all duration-200"
          >
            Start modul
          </a>
        </div>
      </div>

      <!-- Module 7 (B-level - Hidden on Mat C) -->
      <div class="b-level-only group border border-slate-200/80 dark:border-slate-800/80 rounded-2xl bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between hover:shadow-xl hover:border-red-500/50 dark:hover:border-red-400/50 transition-all duration-300 hover:scale-[1.01]">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-50 text-red-600 dark:bg-red-950/60 dark:text-red-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 8v8m-4-5v5m-4-2v2M2 4h12a2 2 0 012 2v12a2 2 0 01-2 2H2a2 2 0 01-2-2V6a2 2 0 012-2z" />
            </svg>
          </div>
          <div>
